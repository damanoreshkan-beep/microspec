{
  "id": "dou",
  "theme": "dim",
  "fav": { "key": "link" },
  "filters": {
    "refetch": true,
    "defaults": { "category": "Front End", "exp": "" },
    "controls": [
      { "type": "select", "key": "category", "label": "filterCategory", "icon": "lucide:layers", "optionsFrom": "categories", "refetch": true },
      { "type": "toggle", "key": "fbron", "label": "filterBron", "icon": "lucide:shield-check", "iconCls": "text-primary", "chip": true },
      { "type": "toggle", "key": "fremote", "label": "filterRemote", "icon": "lucide:house-wifi", "chip": true },
      { "type": "toggle", "key": "fsalary", "label": "filterSalary", "icon": "lucide:banknote", "chip": true },
      { "type": "segment", "key": "exp", "label": "filterExp", "icon": "lucide:briefcase", "refetch": true,
        "options": [["", "expAny"], ["0-1", "0–1"], ["1-3", "1–3"], ["3-5", "3–5"], ["5plus", "5+"]] }
    ]
  },
  "profile": { "icon": "lucide:user", "theme": true, "lang": true, "install": true, "source": { "label": "profSource", "url": "https://jobs.dou.ua/", "icon": "lucide:database" } },
  "tabs": [
    {
      "id": "feed", "type": "list", "icon": "lucide:newspaper", "label": "dockFeed",
      "search": true, "searchKey": "search", "statusKey": "statusCounts",
      "banner": { "icon": "lucide:shield-check", "titleKey": "infoTitle", "bodyKey": "infoBody" },
      "clientFilters": [{ "key": "fbron", "when": "bron" }, { "key": "fremote", "when": "remote" }, { "key": "fsalary", "when": "salary" }],
      "sections": [
        { "filter": "bron", "icon": "lucide:shield-check", "label": "sectionBron", "accent": true, "hideBadge": "bron" },
        { "filter": "!bron", "icon": "lucide:layout-list", "label": "sectionAll", "labelParams": "category" }
      ],
      "card": {
        "layout": "feed", "href": "link", "title": "position", "subtitle": "company", "more": "more", "body": "desc", "meta": { "field": "ts", "format": "ago" },
        "badges": [
          { "key": "bron", "when": "bron", "label": "badgeBron", "icon": "lucide:shield-check", "variant": "primary" },
          { "field": "salary", "variant": "success" },
          { "field": "tech", "variant": "ghost" },
          { "when": "remote", "label": "chipRemote", "variant": "ghost" },
          { "field": "city", "variant": "ghost" }
        ]
      }
    },
    {
      "id": "saved", "type": "list", "icon": "lucide:bookmark", "label": "dockSaved", "source": "fav",
      "titleKey": "dockSaved", "search": true, "searchKey": "searchSaved",
      "empty": { "icon": "lucide:bookmark", "text": "emptySaved", "hint": "emptySavedHint" },
      "card": {
        "layout": "feed", "href": "link", "title": "position", "subtitle": "company", "more": "more", "body": "desc", "meta": { "field": "ts", "format": "ago" },
        "badges": [
          { "field": "salary", "variant": "success" },
          { "field": "tech", "variant": "ghost" },
          { "when": "remote", "label": "chipRemote", "variant": "ghost" },
          { "field": "city", "variant": "ghost" }
        ]
      }
    },
    { "id": "me", "type": "profile", "icon": "lucide:user", "label": "dockMe", "titleKey": "titleProfile" }
  ],
