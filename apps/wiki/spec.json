{
  "id": "wiki",
  "theme": "signal-light",
  "category": "feeds",
  "localized": true,
  "fav": {
    "key": "id"
  },
  "filters": {
    "refetch": true,
    "defaults": {
      "lang": "uk"
    },
    "controls": [
      {
        "type": "segment",
        "key": "lang",
        "label": "fLang",
        "icon": "lucide:globe",
        "refetch": true,
        "chip": true,
        "options": [
          [
            "uk",
            "UK"
          ],
          [
            "en",
            "EN"
          ],
          [
            "de",
            "DE"
          ],
          [
            "pl",
            "PL"
          ]
        ]
      }
    ]
  },
  "detail": {
    "image": "thumb",
    "imageFit": "contain",
    "title": "title",
    "subtitle": "desc",
    "rows": [
      {
        "field": "extract",
        "label": "detailAbout",
        "icon": "lucide:book-open"
      },
      {
        "field": "langName",
        "label": "detailLang",
        "icon": "lucide:globe"
      }
    ],
    "actions": [
      {
        "href": "url",
        "label": "readOn",
        "icon": "lucide:external-link"
      }
    ]
  },
  "profile": {
    "icon": "lucide:book-open-text",
    "theme": true,
    "lang": true,
    "install": true,
    "source": {
      "label": "profSource",
      "url": "https://www.wikipedia.org/",
      "icon": "lucide:database"
    }
  },
  "tabs": [
    {
      "id": "search",
      "type": "list",
      "icon": "lucide:search",
      "label": "tabSearch",
      "search": true,
      "searchFetch": true,
      "searchKey": "search",
      "statusKey": "status",
      "paginate": true,
      "prompt": {
        "icon": "lucide:book-open-text",
        "text": "searchPrompt",
        "hint": "searchPromptHint"
      },
      "empty": {
        "icon": "lucide:search-x",
        "text": "noResults",
        "hint": "noResultsHint"
      },
      "card": {
        "layout": "feed",
        "image": "thumb",
        "imageFit": "contain",
        "title": "title",
        "body": "desc",
        "more": "more"
      }
    },
    {
      "id": "saved",
      "type": "list",
      "icon": "lucide:bookmark",
      "label": "tabSaved",
      "source": "fav",
      "titleKey": "tabSaved",
      "search": true,
      "searchKey": "searchSaved",
      "empty": {
        "icon": "lucide:bookmark",
        "text": "emptySaved",
        "hint": "emptySavedHint"
      },
      "card": {
        "layout": "feed",
        "image": "thumb",
        "imageFit": "contain",
        "title": "title",
        "body": "desc",
        "more": "more"
      }
    },
    {
      "id": "me",
      "type": "profile",
      "icon": "lucide:user",
      "label": "tabMe",
      "titleKey": "tabMe"
    }
  ]
}
