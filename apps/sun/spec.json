{
  "id": "sun",
  "theme": "signal",
  "filters": {
    "defaults": { "bodies": ["moon", "mercury", "venus", "mars", "jupiter", "saturn"] },
    "controls": [
      { "type": "multi", "key": "bodies", "label": "fBodies", "icon": "lucide:orbit", "options": [["moon", "bMoon"], ["mercury", "bMercury"], ["venus", "bVenus"], ["mars", "bMars"], ["jupiter", "bJupiter"], ["saturn", "bSaturn"], ["uranus", "bUranus"], ["neptune", "bNeptune"], ["pluto", "bPluto"]] }
    ]
  },
  "tabs": [
    {
      "id": "compass",
      "type": "tool",
      "icon": "lucide:sun",
      "label": "tabCompass",
      "view": "sun",
      "needs": [
        "geo"
      ]
    },
    {
      "id": "me",
      "type": "profile",
      "icon": "lucide:user",
      "label": "tabMe",
      "titleKey": "tabMe"
    }
  ],
  "profile": {
    "icon": "lucide:sun",
    "theme": true,
    "lang": true,
    "install": true,
    "permissions": [
      "geolocation",
      "motion"
    ],
    "source": {
      "label": "profSource",
      "url": "https://github.com/mourner/suncalc",
      "icon": "lucide:database"
    }
  }
}
