{
  "id": "nearby",
  "theme": "signal",
  "fav": {
    "key": "id"
  },
  "filters": {
    "refetch": true,
    "defaults": {
      "category": "pharmacy"
    },
    "controls": [
      {
        "type": "select",
        "key": "category",
        "label": "fCat",
        "icon": "lucide:layers",
        "optionsFrom": "categories",
        "refetch": true,
        "chip": true
      }
    ]
  },
  "detail": {
    "title": "name",
    "subtitle": "addr",
    "rows": [
      {
        "icon": "lucide:footprints",
        "label": "detDist",
        "field": "distStr"
      },
      {
        "icon": "lucide:tag",
        "label": "detKind",
        "field": "tag"
      }
    ],
    "actions": [
      {
        "icon": "lucide:map",
        "label": "open",
        "href": "maps"
      }
    ]
  },
  "tabs": [
    {
      "id": "list",
      "type": "list",
      "icon": "lucide:map-pin",
      "label": "tabList",
      "search": true,
      "searchKey": "search",
      "statusKey": "status",
      "empty": {
        "icon": "lucide:map-pin-off",
        "text": "noResults",
        "hint": "noResultsHint"
      },
      "card": {
        "layout": "feed",
        "href": "maps",
        "title": "name",
        "subtitle": "addr",
        "more": "more",
        "badges": [
          {
            "field": "distStr"
          }
        ]
      }
    },
    {
      "id": "saved",
      "type": "list",
      "icon": "lucide:bookmark",
      "label": "tabSaved",
      "source": "fav",
      "titleKey": "tabSaved",
      "search": true,
      "searchKey": "searchSaved",
      "empty": {
        "icon": "lucide:bookmark",
        "text": "emptySaved",
        "hint": "emptySavedHint"
      },
      "card": {
        "layout": "feed",
        "href": "maps",
        "title": "name",
        "subtitle": "addr",
        "more": "more",
        "badges": [
          {
            "field": "distStr"
          }
        ]
      }
    },
    {
      "id": "me",
      "type": "profile",
      "icon": "lucide:user",
      "label": "tabMe",
      "titleKey": "tabMe"
    }
  ],
  "profile": {
    "icon": "lucide:map-pin",
    "theme": true,
    "lang": true,
    "install": true,
    "permissions": [
      "geolocation"
    ],
    "source": {
      "label": "profSource",
      "url": "https://www.openstreetmap.org/",
      "icon": "lucide:database"
    }
  }
}
