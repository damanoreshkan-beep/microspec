{
  "id": "cinema",
  "theme": "signal",
  "category": "feeds",
  "translate": [
    "desc"
  ],
  "fav": {
    "key": "id"
  },
  "tabs": [
    {
      "id": "films",
      "type": "list",
      "icon": "lucide:clapperboard",
      "label": "tabFilms",
      "search": true,
      "card": {
        "layout": "feed",
        "title": "title",
        "body": "desc",
        "image": "thumb",
        "badges": [
          {
            "field": "year",
            "icon": "lucide:calendar"
          },
          {
            "field": "views",
            "icon": "lucide:eye"
          }
        ]
      }
    },
    {
      "id": "saved",
      "type": "list",
      "icon": "lucide:bookmark",
      "label": "tabSaved",
      "card": {
        "layout": "feed",
        "title": "title",
        "body": "desc",
        "image": "thumb"
      },
      "source": "fav",
      "titleKey": "tabSaved",
      "empty": {
        "icon": "lucide:bookmark",
        "text": "emptySaved"
      }
    },
    {
      "id": "me",
      "type": "profile",
      "icon": "lucide:user",
      "label": "tabMe",
      "titleKey": "tabMe"
    }
  ],
  "detail": {
    "title": "title",
    "image": "thumb",
    "imageFit": "cover",
    "body": "desc",
    "rows": [
      {
        "field": "year",
        "label": "rYear",
        "icon": "lucide:calendar"
      },
      {
        "field": "views",
        "label": "rViews",
        "icon": "lucide:eye"
      }
    ],
    "actions": [
      {
        "label": "watch",
        "play": "video",
        "icon": "lucide:play"
      },
      {
        "label": "source",
        "href": "url",
        "icon": "lucide:archive"
      }
    ]
  },
  "profile": {
    "icon": "lucide:clapperboard",
    "theme": true,
    "lang": true,
    "install": true,
    "source": {
      "label": "profSource",
      "url": "https://archive.org/details/feature_films",
      "icon": "lucide:archive"
    }
  },
  "filters": {
    "refetch": true,
    "defaults": {
      "lang": "",
      "era": ""
    },
    "controls": [
      {
        "type": "select",
        "key": "lang",
        "label": "fLang",
        "icon": "lucide:languages",
        "refetch": true,
        "chip": true,
        "options": [
          [
            "",
            "fAny"
          ],
          [
            "en",
            "lEn"
          ],
          [
            "es",
            "lEs"
          ],
          [
            "de",
            "lDe"
          ],
          [
            "tr",
            "lTr"
          ],
          [
            "fr",
            "lFr"
          ],
          [
            "ja",
            "lJa"
          ],
          [
            "it",
            "lIt"
          ],
          [
            "ru",
            "lRu"
          ],
          [
            "uk",
            "lUk"
          ]
        ]
      },
      {
        "type": "select",
        "key": "era",
        "label": "fEra",
        "icon": "lucide:calendar-range",
        "refetch": true,
        "chip": true,
        "options": [
          [
            "",
            "fAny"
          ],
          [
            "silent",
            "eSilent"
          ],
          [
            "golden",
            "eGolden"
          ],
          [
            "mid",
            "eMid"
          ],
          [
            "late",
            "eLate"
          ],
          [
            "modern",
            "eModern"
          ]
        ]
      }
    ]
  }
}
